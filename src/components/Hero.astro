---
import WaveText from "./WaveText.astro";
const message = "✨ Algo especial se acerca ✨";
---

<section class="hero" id="hero">
  <div class="hero-inner">
    <WaveText
      text={message}
      amplitude={30}
      frequency={0.9}
      charWidth={28}
      fontSize={34}
      speed={1.2}
    />
    <div class="scroll-hint" id="scroll-hint">
      <span>Baja para ver tu sorpresa</span>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M12 5v14M5 12l7 7 7-7" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  </div>
</section>

<script>
  const heroSection  = document.getElementById("hero") as HTMLElement;
  const scrollHint   = document.getElementById("scroll-hint") as HTMLElement;

  function onScroll() {
    const progress = Math.min(window.scrollY / heroSection.offsetHeight, 1);
    // El hint de scroll se desvanece al empezar a bajar
    scrollHint.style.opacity = String(Math.max(0, 1 - progress * 4));
  }

  window.addEventListener("scroll", onScroll, { passive: true });
</script>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100vh;
    background: radial-gradient(ellipse at 50% 40%, #1e1040 0%, var(--color-bg) 70%);
    overflow: hidden;
  }

  /* Estrellas decorativas */
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 20% 30%, rgba(255,255,255,0.6) 0%, transparent 100%),
      radial-gradient(1px 1px at 60% 15%, rgba(255,255,255,0.4) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 80% 70%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(1px 1px at 10% 80%, rgba(255,255,255,0.3) 0%, transparent 100%),
      radial-gradient(1px 1px at 45% 90%, rgba(255,255,255,0.4) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 90% 40%, rgba(255,255,255,0.6) 0%, transparent 100%);
    pointer-events: none;
  }

  .hero-inner {
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
  }

  /* Estilo del texto de la ola — hereda al WaveText */
  .hero-inner :global(.wt-char) {
    color: var(--color-text);
    font-family: var(--font-display);
    font-weight: 400;
    text-shadow:
      0 0 20px rgba(224, 64, 251, 0.5),
      0 0 50px rgba(124, 77, 255, 0.25);
  }

  .scroll-hint {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    animation: pulse 2s ease-in-out infinite;
    transition: opacity 0.2s ease;
  }

  @keyframes pulse {
    0%, 100% { transform: translateY(0); opacity: 0.7; }
    50% { transform: translateY(6px); opacity: 1; }
  }
</style>
