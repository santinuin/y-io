---
import WaveText from "./WaveText.astro";
const message = "Amoooooooooooooooooooooooollll";
---

<!--
  hero-sticky-wrapper: 300vh de alto
  → el hero queda fijo (sticky) los primeros 100vh del viewport
    mientras el usuario scrollea los 200vh de espacio de animación.
  → cuando scrollProgress llega a 1, el sticky se "suelta" y
    la sección de regalos sube naturalmente.
-->
<div class="hero-sticky-wrapper" id="hero-sticky-wrapper">
  <section class="hero" id="hero">
    <div class="hero-inner">
      <WaveText
        text={message}
        amplitude={32}
        frequency={0.85}
        charWidth={24}
        fontSize={34}
        speed={1.1}
        scrollDriven={true}
      />
      <div class="scroll-hint" id="scroll-hint">
        <span>Bajá para ver tu sorpresa</span>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M12 5v14M5 12l7 7 7-7" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>
  </section>
</div>

<script>
  const wrapper   = document.getElementById("hero-sticky-wrapper") as HTMLElement;
  const scrollHint = document.getElementById("scroll-hint") as HTMLElement;

  function onScroll() {
    const scrollableH = wrapper.offsetHeight - window.innerHeight; // 200vh aprox
    const progress    = Math.min(window.scrollY / scrollableH, 1);

    // El hint desaparece en el primer 20% del scroll
    scrollHint.style.opacity = String(Math.max(0, 1 - progress * 5));
  }

  window.addEventListener("scroll", onScroll, { passive: true });
</script>

<style>
  /* Wrapper alto: da el espacio de scroll que "consume" la animación */
  .hero-sticky-wrapper {
    height: 300vh;
  }

  /* El hero ocupa 100vh y se queda pegado al top mientras el wrapper scrollea */
  .hero {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(ellipse at 50% 40%, #1e1040 0%, var(--color-bg) 70%);
    overflow: hidden;
  }

  /* Estrellas decorativas */
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 20% 30%, rgba(255,255,255,0.6) 0%, transparent 100%),
      radial-gradient(1px 1px at 60% 15%, rgba(255,255,255,0.4) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 80% 70%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(1px 1px at 10% 80%, rgba(255,255,255,0.3) 0%, transparent 100%),
      radial-gradient(1px 1px at 45% 90%, rgba(255,255,255,0.4) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 90% 40%, rgba(255,255,255,0.6) 0%, transparent 100%);
    pointer-events: none;
  }

  .hero-inner {
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
  }

  .hero-inner :global(.wt-char) {
    color: var(--color-text);
    font-family: var(--font-display);
    font-weight: 400;
    text-shadow:
      0 0 20px rgba(224, 64, 251, 0.5),
      0 0 50px rgba(124, 77, 255, 0.25);
  }

  .scroll-hint {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    animation: pulse 2s ease-in-out infinite;
    transition: opacity 0.2s ease;
  }

  @keyframes pulse {
    0%, 100% { transform: translateY(0); opacity: 0.7; }
    50%       { transform: translateY(6px); opacity: 1; }
  }
</style>
