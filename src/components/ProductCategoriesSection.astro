---
interface Gift {
  id:          string;
  label:       string;
  emoji:       string;
  desc:        string;
  boxColor:    string;
  lidColor:    string;
  ribbonColor: string;
  video?:      string;  // ruta relativa a /public, ej: /videos/viaje.mp4
}

const gifts: Gift[] = [
  { id: "viaje",     label: "Viajecito",          emoji: "✈️", desc: "Escapada en vacaciones de invierno a lugar a definir",  boxColor: "#FFA726", lidColor: "#FB8C00", ribbonColor: "#F06292" },
  { id: "tablet",    label: "Tablet",             emoji: "📱", desc: "Chiche para mirar tus series de noche",                 boxColor: "#42A5F5", lidColor: "#1E88E5", ribbonColor: "#FFEE58" },
  { id: "ebook",     label: "Ebook",              emoji: "📚", desc: "Pa que nunca te quedes sin leer",                       boxColor: "#66BB6A", lidColor: "#43A047", ribbonColor: "#EF5350" },
  { id: "cena",      label: "Cena",               emoji: "🍷", desc: "Comer como unos gorditos en papagaio",                  boxColor: "#EF5350", lidColor: "#E53935", ribbonColor: "#FFEE58" },
  { id: "spa",       label: "Masajitos",          emoji: "💆", desc: "Masajitos en los pies",                                 boxColor: "#AB47BC", lidColor: "#8E24AA", ribbonColor: "#80DEEA" },
  { id: "concierto", label: "Concierto",          emoji: "🎶", desc: "Entradas para ver a Ricky Martin",                      boxColor: "#26C6DA", lidColor: "#00ACC1", ribbonColor: "#FF8A65" },
  { id: "cab",       label: "CAB",                emoji: "🏴‍☠️", desc: "Abono pa ver al pirata",                                boxColor: "#FFEE58", lidColor: "#FDD835", ribbonColor: "#7E57C2" },
];
---

<section class="pcs" id="pcs">

  <div class="pcs-header">
    <h2 class="pcs-title">Peeeeeeeeeeeeeeeero <br> pues indeciso y ansioso...</h2>
    <p class="pcs-subtitle">Te hago una listita de los posibles regalos que tenía en mente pa tu inminente cumpleañito'</p>
    <p class="pcs-hint">¡Clickea las cajitas para ver qué tienen adentro!</p>
  </div>

  <!-- Contenedor estrecho: las cajas caen unas sobre otras -->
  <div class="pcs-pool-wrap">
    <div class="pcs-pool" id="pcs-pool">
      <ul class="pcs-list" id="pcs-list">
        {gifts.map((g, i) => (
          <li
            class="pcs-box"
            id={`box-${g.id}`}
            data-index={i}
            style={`--bc: ${g.boxColor}; --lc: ${g.lidColor}; --rc: ${g.ribbonColor};`}
          >
            <!-- Caja de regalo en CSS -->
            <div class="gb">
              <!-- Moño -->
              <div class="gb-bow-wrap">
                <div class="gb-bow-l"></div>
                <div class="gb-bow-r"></div>
                <div class="gb-bow-knot"></div>
                <!-- Cinta vertical sobre el moño -->
                <div class="gb-bow-ribbon"></div>
              </div>
              <!-- Tapa -->
              <div class="gb-lid">
                <div class="gb-lid-ribbon"></div>
              </div>
              <!-- Cuerpo -->
              <div class="gb-body">
                <!-- Las cintas horizontales y vertical se dibujan con pseudo-elementos -->
              </div>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Overlay: se muestra al hacer clic en una caja -->
  <div class="pcs-overlay" id="pcs-overlay" aria-hidden="true">
    <div class="pcs-card">
      <div class="pcs-card-emoji"  id="pcs-card-emoji">🎁</div>
      <h3  class="pcs-card-title"  id="pcs-card-title">Regalo</h3>
      <p   class="pcs-card-desc"   id="pcs-card-desc">¡Una sorpresa especial para vos!</p>
      <div class="pcs-card-actions">
        <button class="pcs-card-choose" id="pcs-card-choose">Elegir 🎁</button>
        <button class="pcs-card-close"  id="pcs-card-close">Volver ✕</button>
      </div>
    </div>
  </div>

  <!-- Audio independiente del video. Ponés el archivo en /public/audio/ y completás el src -->
  <audio id="pcs-audio" loop src="/audio/chamame.mp3"></audio>

  <!-- Overlay de video (encima de todo) -->
  <div class="pcs-video-overlay" id="pcs-video-overlay" aria-hidden="true">
    <canvas id="pcs-fireworks" class="pcs-fireworks"></canvas>
    <video
      id="pcs-video"
      autoplay
      loop
      playsinline
      class="pcs-video"
    ></video>
    <button class="pcs-video-close" id="pcs-video-close" aria-label="Cerrar video">✕</button>
  </div>

</section>

<script>
  import Matter from "matter-js";
  const { Engine, Runner, Bodies, Events, Composite, Mouse, MouseConstraint, Query, Body } = Matter;

  /* ── DOM ── */
  const section      = document.getElementById("pcs")!;
  const pool         = document.getElementById("pcs-pool")!;
  const list         = document.getElementById("pcs-list")!;
  const overlay      = document.getElementById("pcs-overlay")!;
  const cardEmoji    = document.getElementById("pcs-card-emoji")!;
  const cardTitle    = document.getElementById("pcs-card-title")!;
  const cardDesc     = document.getElementById("pcs-card-desc")!;
  const closeBtn     = document.getElementById("pcs-card-close")!;
  const chooseBtn    = document.getElementById("pcs-card-choose")!;
  const videoOverlay = document.getElementById("pcs-video-overlay")!;
  const videoEl      = document.getElementById("pcs-video") as HTMLVideoElement;
  const videoClose   = document.getElementById("pcs-video-close")!;
  const audioEl      = document.getElementById("pcs-audio") as HTMLAudioElement;
  const fwCanvas     = document.getElementById("pcs-fireworks") as HTMLCanvasElement;
  const fwCtx        = fwCanvas.getContext("2d")!;

  /* ══════════════════════════════════════════
     FUEGOS ARTIFICIALES
  ══════════════════════════════════════════ */
  let fwRaf = 0;

  interface Particle {
    x: number; y: number;
    vx: number; vy: number;
    alpha: number; decay: number;
    radius: number; color: string;
  }

  interface Rocket {
    x: number; y: number;
    vy: number; targetY: number;
    color: string; exploded: boolean;
    particles: Particle[];
  }

  const COLORS = [
    "#ff85a1", "#ffee58", "#ffffff", "#80deea",
    "#ff6b8e", "#ce93d8", "#a5d6a7", "#ffb74d",
  ];

  const rockets: Rocket[] = [];

  function randomColor() {
    return COLORS[Math.floor(Math.random() * COLORS.length)];
  }

  function launchRocket() {
    const x = fwCanvas.width * (0.15 + Math.random() * 0.7);
    rockets.push({
      x, y: fwCanvas.height,
      vy: -(10 + Math.random() * 6),
      targetY: fwCanvas.height * (0.15 + Math.random() * 0.45),
      color: randomColor(),
      exploded: false,
      particles: [],
    });
  }

  function explode(r: Rocket) {
    r.exploded = true;
    const count = 80 + Math.floor(Math.random() * 60);
    for (let i = 0; i < count; i++) {
      const angle = (Math.PI * 2 * i) / count + (Math.random() - 0.5) * 0.3;
      const speed = 1.5 + Math.random() * 4;
      r.particles.push({
        x: r.x, y: r.y,
        vx: Math.cos(angle) * speed,
        vy: Math.sin(angle) * speed,
        alpha: 1,
        decay: 0.012 + Math.random() * 0.01,
        radius: 2 + Math.random() * 2,
        color: r.color,
      });
    }
  }

  function fireworksFrame() {
    fwCtx.fillStyle = "rgba(0,0,0,0.18)";
    fwCtx.fillRect(0, 0, fwCanvas.width, fwCanvas.height);

    // Lanzar cohete cada ~40 frames
    if (Math.random() < 0.025) launchRocket();

    for (let i = rockets.length - 1; i >= 0; i--) {
      const r = rockets[i];

      if (!r.exploded) {
        r.y += r.vy;
        // Estela del cohete
        fwCtx.beginPath();
        fwCtx.arc(r.x, r.y, 3, 0, Math.PI * 2);
        fwCtx.fillStyle = r.color;
        fwCtx.fill();

        if (r.y <= r.targetY) explode(r);
      }

      // Partículas
      for (let j = r.particles.length - 1; j >= 0; j--) {
        const p = r.particles[j];
        p.x  += p.vx;
        p.y  += p.vy;
        p.vy += 0.08; // gravedad
        p.vx *= 0.98;
        p.alpha -= p.decay;

        if (p.alpha <= 0) { r.particles.splice(j, 1); continue; }

        fwCtx.globalAlpha = p.alpha;
        fwCtx.beginPath();
        fwCtx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
        fwCtx.fillStyle = p.color;
        fwCtx.fill();
      }
      fwCtx.globalAlpha = 1;

      if (r.exploded && r.particles.length === 0) rockets.splice(i, 1);
    }

    fwRaf = requestAnimationFrame(fireworksFrame);
  }

  function startFireworks() {
    fwCanvas.width  = window.innerWidth;
    fwCanvas.height = window.innerHeight;
    rockets.length  = 0;
    fwCtx.clearRect(0, 0, fwCanvas.width, fwCanvas.height);
    // Lanzar algunos cohetes iniciales de golpe
    for (let i = 0; i < 4; i++) launchRocket();
    fwRaf = requestAnimationFrame(fireworksFrame);
  }

  function stopFireworks() {
    cancelAnimationFrame(fwRaf);
    fwCtx.clearRect(0, 0, fwCanvas.width, fwCanvas.height);
    rockets.length = 0;
  }

  // ── Cuando tengas el archivo, cambiá esta constante ──
  const GIFT_AUDIO = "/audio/chamame.mp3"; // ej: "/audio/cancion.mp3"
  const boxEls       = Array.from(list.querySelectorAll<HTMLElement>(".pcs-box"));

  /* ── Datos (espejo del frontmatter) ── */
  const GIFTS = [
    { id: "viaje",     label: "Viajecito",  emoji: "✈️", desc: "Escapada en vacaciones de invierno a lugar a definir" },
    { id: "tablet",    label: "Tablet",     emoji: "📱", desc: "Chiche para mirar tus series de noche"                },
    { id: "ebook",     label: "Ebook",      emoji: "📚", desc: "Pa que nunca te quedes sin leer"                      },
    { id: "cena",      label: "Cena",       emoji: "🍷", desc: "Comer como unos gorditos en papagaio"                 },
    { id: "spa",       label: "Masajitos",  emoji: "💆", desc: "Masajitos en los pies"                                },
    { id: "concierto", label: "Concierto",  emoji: "🎶", desc: "Entradas para ver a Ricky Martin"                    },
    { id: "cab",       label: "CAB",        emoji: "🏴‍☠️", desc: "Abono pa ver al pirata"                              },
  ];

  const GIFT_VIDEO = "/videos/coqui-baile.mp4";

  /* Dimensiones de la caja — deben coincidir con el CSS */
  const BOX_W = 120;
  const BOX_H = 105;

  let initialized = false;

  /* ══════════════════════════════════════════
     FÍSICA
  ══════════════════════════════════════════ */
  function initPhysics() {
    const W = pool.offsetWidth;
    const H = pool.offsetHeight;

    /* Aplicar tamaño CSS a los <li> */
    boxEls.forEach((li) => {
      li.style.width  = `${BOX_W}px`;
      li.style.height = `${BOX_H}px`;
    });

    const engine = Engine.create({ gravity: { x: 0, y: 1.4 } });

    /* Paredes */
    const t = 50;
    Composite.add(engine.world, [
      Bodies.rectangle(W / 2, H + t / 2, W + t * 2, t, { isStatic: true, label: "wall" }),
      Bodies.rectangle(-t / 2,   H / 2,  t, H * 2,  { isStatic: true, label: "wall" }),
      Bodies.rectangle(W + t / 2, H / 2, t, H * 2,  { isStatic: true, label: "wall" }),
    ]);

    /* Cajas rectangulares — caen desde arriba, centradas en el pool estrecho */
    const bodies = GIFTS.map((_, i) => {
      // Con pool estrecho, casi 1 columna — dispersión horizontal pequeña
      const x = W / 2 + (Math.random() - 0.5) * (W * 0.45);
      const y = -BOX_H / 2 - i * (BOX_H + 15) - Math.random() * 20;
      return Bodies.rectangle(x, y, BOX_W, BOX_H, {
        restitution: 0.2,
        friction:    0.7,
        frictionAir: 0.02,
        label:       GIFTS[i].id,
      });
    });
    Composite.add(engine.world, bodies);

    /* Sincronizar DOM con físicas */
    Events.on(engine, "afterUpdate", () => {
      bodies.forEach((body, i) => {
        const x = body.position.x - BOX_W / 2;
        const y = body.position.y - BOX_H / 2;
        boxEls[i].style.transform =
          `translate(${x.toFixed(1)}px, ${y.toFixed(1)}px) rotate(${body.angle.toFixed(4)}rad)`;
      });
    });

    /* MouseConstraint — arrastrar cajas */
    const mouse = Mouse.create(pool);
    mouse.pixelRatio = window.devicePixelRatio || 1;
    Composite.add(engine.world, MouseConstraint.create(engine, {
      mouse,
      constraint: { stiffness: 0.15, damping: 0.1, render: { visible: false } },
    }));

    /* En mobile, permitir scroll cuando el dedo cae en área vacía.
       Interceptamos touchstart Y touchmove en fase de captura (antes que
       los listeners de Matter.js en bubble), de modo que Matter.js nunca
       llame preventDefault() y el navegador pueda scrollear. */
    let touchOnBody = false;

    pool.addEventListener("touchstart", (e: TouchEvent) => {
      const rect  = pool.getBoundingClientRect();
      const touch = e.touches[0];
      const point = { x: touch.clientX - rect.left, y: touch.clientY - rect.top };
      touchOnBody = Query.point(bodies, point).length > 0;
      if (!touchOnBody) e.stopImmediatePropagation();
    }, { capture: true, passive: true });

    pool.addEventListener("touchmove", (e: TouchEvent) => {
      if (!touchOnBody) e.stopImmediatePropagation();
    }, { capture: true, passive: true });

    pool.addEventListener("touchend", () => {
      touchOnBody = false;
    }, { capture: true, passive: true });

    /* Clic vs drag */
    let downX = 0, downY = 0, dragging = false;
    pool.addEventListener("pointerdown", (e: PointerEvent) => { downX = e.clientX; downY = e.clientY; dragging = false; });
    pool.addEventListener("pointermove", (e: PointerEvent) => {
      if (Math.abs(e.clientX - downX) > 8 || Math.abs(e.clientY - downY) > 8) dragging = true;
    });
    pool.addEventListener("pointerup", (e: PointerEvent) => {
      if (dragging) return;
      const rect  = pool.getBoundingClientRect();
      const point = { x: e.clientX - rect.left, y: e.clientY - rect.top };
      const hits  = Query.point(bodies, point);
      if (hits.length > 0) {
        const idx = bodies.indexOf(hits[0]);
        if (idx >= 0) {
          boxEls[idx].classList.add("revealed");
          showGift(idx);
        }
      }
    });

    /* Hover: ilumina la caja bajo el cursor */
    let hoveredIdx = -1;
    pool.addEventListener("mousemove", (e: MouseEvent) => {
      const rect  = pool.getBoundingClientRect();
      const point = { x: e.clientX - rect.left, y: e.clientY - rect.top };
      const hits  = Query.point(bodies, point);

      const newIdx = hits.length > 0 ? bodies.indexOf(hits[0]) : -1;
      if (newIdx !== hoveredIdx) {
        if (hoveredIdx >= 0) boxEls[hoveredIdx].classList.remove("hovered");
        hoveredIdx = newIdx;
        if (hoveredIdx >= 0) boxEls[hoveredIdx].classList.add("hovered");
      }
      pool.style.cursor = newIdx >= 0 ? "pointer" : "default";
    });
    pool.addEventListener("mouseleave", () => {
      if (hoveredIdx >= 0) boxEls[hoveredIdx].classList.remove("hovered");
      hoveredIdx = -1;
    });

    /* Runner + auto-pausa cuando todo se calma */
    const runner = Runner.create();
    Runner.run(runner, engine);

    let stillFrames = 0;
    Events.on(engine, "afterUpdate", () => {
      const allStill = Composite.allBodies(engine.world)
        .filter(b => !b.isStatic).every(b => b.speed < 0.4);
      stillFrames = allStill ? stillFrames + 1 : 0;
      if (stillFrames > 120) Runner.stop(runner);
    });
    pool.addEventListener("pointerdown", () => { stillFrames = 0; Runner.run(runner, engine); });
  }

  /* ══════════════════════════════════════════
     OVERLAY REGALO
  ══════════════════════════════════════════ */
  let activeGiftIdx = -1;

  function showGift(idx: number) {
    activeGiftIdx = idx;
    const g = GIFTS[idx];
    cardEmoji.textContent = g.emoji;
    cardTitle.textContent = g.label;
    cardDesc.textContent  = g.desc;
    overlay.classList.add("visible");
    overlay.setAttribute("aria-hidden", "false");
  }

  function closeOverlay() {
    overlay.classList.remove("visible");
    overlay.setAttribute("aria-hidden", "true");
    activeGiftIdx = -1;
  }

  closeBtn.addEventListener("click", closeOverlay);
  overlay.addEventListener("click", (e) => { if (e.target === overlay) closeOverlay(); });

  /* ══════════════════════════════════════════
     OVERLAY VIDEO
  ══════════════════════════════════════════ */
  function showVideo(src: string) {
    videoEl.src = src;
    videoEl.load();
    videoEl.play().catch(() => {});

    if (GIFT_AUDIO) {
      audioEl.src = GIFT_AUDIO;
      audioEl.load();
      audioEl.play().catch(() => {});
    }

    videoOverlay.classList.add("visible");
    videoOverlay.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
    startFireworks();
  }

  function closeVideo() {
    videoOverlay.classList.remove("visible");
    videoOverlay.setAttribute("aria-hidden", "true");
    videoEl.pause();
    videoEl.src = "";
    audioEl.pause();
    audioEl.src = "";
    document.body.style.overflow = "";
    stopFireworks();
  }

  chooseBtn.addEventListener("click", () => {
    showVideo(GIFT_VIDEO);
  });

  videoClose.addEventListener("click", closeVideo);
  videoOverlay.addEventListener("click", (e) => { if (e.target === videoOverlay) closeVideo(); });

  /* ══════════════════════════════════════════
     INTERSECTION OBSERVER
  ══════════════════════════════════════════ */
  new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting && !initialized) {
      initialized = true;
      initPhysics();
    }
  }, { threshold: 0.2 }).observe(section);
</script>

<style>
  /* ══ Sección ══ */
  .pcs {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 3rem;
    padding-bottom: 3rem;
    overflow: hidden;
  }

  /* ══ Encabezado ══ */
  .pcs-header {
    text-align: center;
    max-width: 540px;
    padding: 0 1rem 1.5rem;
    z-index: 1;
  }
  .pcs-title {
    font-size: clamp(1.5rem, 4vw, 2.4rem);
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 0.4rem;
  }
  .pcs-subtitle {
    color: rgba(255,255,255,0.8);
    font-size: 1rem;
    margin-bottom: 0.3rem;
  }
  .pcs-hint {
    color: rgba(255,255,255,0.65);
    font-size: 0.85rem;
    letter-spacing: 0.05em;
  }

  /* ══ Pool estrecho centrado ══ */
  .pcs-pool-wrap {
    display: flex;
    justify-content: center;
    width: 100%;
  }
  .pcs-pool {
    position: relative;
    width: min(420px, 92vw);
    height: 680px;
    overflow: hidden;
    border: 3px solid rgba(255,255,255,0.5);
    border-radius: 0;
    background: rgba(255,255,255,0.12);
    cursor: default;
  }

  .pcs-list {
    position: relative;
    width: 100%;
    height: 100%;
    list-style: none;
    padding: 0; margin: 0;
  }

  /* ══ Cada caja — posición manejada por Matter.js ══ */
  .pcs-box {
    position: absolute;
    top: 0; left: 0;
    will-change: transform;
    pointer-events: none;   /* el pool recibe los eventos del mouse */
  }

  /* Hover: ilumina la caja entera */
  .pcs-box.hovered {
    filter: drop-shadow(0 0 14px rgba(255,255,255,0.9)) brightness(1.2);
    z-index: 10;
  }

  /* Indicador de caja ya revelada */
  .pcs-box.revealed .gb-body::before {
    content: "✓";
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    color: rgba(255,255,255,0.6);
    background: rgba(0,0,0,0.15);
    border: none;
  }

  /* ══ Gift box en CSS ══ */
  .gb {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    position: relative;
    filter: drop-shadow(2px 4px 0px rgba(0,0,0,0.25));
  }

  /* ── Moño ── */
  .gb-bow-wrap {
    position: absolute;
    top: -20px;
    left: 50%;
    transform: translateX(-50%);
    width: 56px;
    height: 36px;
    z-index: 2;
  }
  .gb-bow-l,
  .gb-bow-r {
    position: absolute;
    width: 24px;
    height: 22px;
    background: var(--rc);
    border: 2.5px solid #1a1a1a;
    border-radius: 50% 0 50% 50%;
    top: 4px;
  }
  .gb-bow-l {
    left: 2px;
    transform: rotate(-30deg);
    transform-origin: right center;
  }
  .gb-bow-r {
    right: 2px;
    transform: rotate(30deg);
    transform-origin: left center;
    border-radius: 0 50% 50% 50%;
  }
  .gb-bow-knot {
    position: absolute;
    width: 14px;
    height: 14px;
    background: var(--rc);
    border: 2.5px solid #1a1a1a;
    border-radius: 50%;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 1;
  }
  /* Cinta vertical que baja del moño hacia la tapa */
  .gb-bow-ribbon {
    position: absolute;
    width: 14px;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    height: 14px;
    background: var(--rc);
    border-left: 2px solid #1a1a1a;
    border-right: 2px solid #1a1a1a;
  }

  /* ── Tapa ── */
  .gb-lid {
    height: 28%;
    background: var(--lc);
    border: 3px solid #1a1a1a;
    border-radius: 5px 5px 0 0;
    position: relative;
    overflow: hidden;
    z-index: 1;
  }
  /* Cinta vertical en la tapa */
  .gb-lid-ribbon {
    position: absolute;
    top: 0; bottom: 0;
    left: 50%;
    width: 14px;
    transform: translateX(-50%);
    background: var(--rc);
    border-left: 2px solid #1a1a1a;
    border-right: 2px solid #1a1a1a;
  }

  /* ── Cuerpo de la caja ── */
  .gb-body {
    flex: 1;
    background: var(--bc);
    border: 3px solid #1a1a1a;
    border-radius: 0 0 5px 5px;
    position: relative;
    overflow: hidden;
  }
  /* Cinta horizontal */
