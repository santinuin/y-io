---
const stickers = [
  { src: "/stickers/mollo.webp",      size: 130, rotate: -15, top: "3vh",   left: "5vw"   },
  { src: "/stickers/coqui.webp",      size: 118, rotate: 18,  top: "7vh",   right: "7vw"  },
  { src: "/stickers/nara.webp",       size: 140, rotate: -8,  top: "30vh",  left: "2vw"   },
  { src: "/stickers/coqui2.webp",     size: 125, rotate: 22,  top: "22vh",  right: "4vw"  },
  { src: "/stickers/coqui3.webp",     size: 135, rotate: -20, top: "54vh",  left: "6vw"   },
  { src: "/stickers/coquimollo.webp", size: 150, rotate: 9,   top: "46vh",  right: "3vw"  },
  { src: "/stickers/nara2.webp",      size: 128, rotate: 17,  top: "76vh",  left: "3vw"   },
  { src: "/stickers/nara3.webp",      size: 120, rotate: -13, top: "80vh",  right: "8vw"  },
];
---

<div class="stickers-layer" aria-hidden="true">
  {stickers.map((s, i) => {
    const pos = [
      s.top    && `top:${s.top}`,
      s.bottom && `bottom:${s.bottom}`,
      s.left   && `left:${s.left}`,
      s.right  && `right:${s.right}`,
    ].filter(Boolean).join(";");

    return (
      <img
        class="sticker"
        src={s.src}
        alt=""
        width={s.size}
        height={s.size}
        style={`${pos};--size:${s.size}px;--rot:${s.rotate}deg;--delay:${i * 70}ms`}
        loading="lazy"
        draggable="false"
      />
    );
  })}
</div>

<style>
  .stickers-layer {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
  }

  .sticker {
    position: absolute;
    width: var(--size);
    height: var(--size);
    object-fit: contain;
    transform: rotate(var(--rot));
    filter: drop-shadow(2px 4px 8px rgba(0,0,0,0.2));
    animation: sticker-pop 0.5s cubic-bezier(0.34, 1.4, 0.64, 1) var(--delay) both;
  }

  @keyframes sticker-pop {
    from { opacity: 0; transform: rotate(var(--rot)) scale(0.5); }
    to   { opacity: 1; transform: rotate(var(--rot)) scale(1);   }
  }

  @media (max-width: 600px) {
    .sticker {
      width:  calc(var(--size) * 0.6);
      height: calc(var(--size) * 0.6);
    }
  }
</style>
