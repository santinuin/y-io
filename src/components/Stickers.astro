---
// 16 instancias repartidas por todo el viewport (los 8 archivos se repiten).
// Como son position:fixed, siempre decoran el fondo independientemente del scroll.
// El contenido tiene z-index:2 → siempre encima de los stickers.

// nombre completo del archivo (con extensión)
const imgs = [
  "mollo.webp", "coqui.webp", "nara.webp",     "coqui2.webp",
  "coqui3.webp", "coquimollo.webp", "nara2.webp", "nara3.webp",
  "corazon.png", "belgrano.webp",  // índices 8 y 9
];

const stickers = [
  { img: 0, size: 132, rotate: -23, top:  "1vh",  left:  "0vw"  },
  { img: 8, size: 104, rotate:  31, top:  "8vh",  left: "18vw"  },
  { img: 4, size: 145, rotate:  -7, top: "-2vh",  left: "37vw"  },
  { img: 2, size: 118, rotate:  17, top:  "5vh",  left: "58vw"  },
  { img: 6, size: 128, rotate: -38, top:  "0vh",  left: "80vw"  },

  { img: 1, size: 110, rotate:  42, top: "19vh",  left:  "6vw"  },
  { img: 5, size: 138, rotate: -15, top: "24vh",  left: "28vw"  },
  { img: 9, size: 122, rotate:  27, top: "16vh",  left: "49vw"  },
  { img: 3, size: 115, rotate: -33, top: "22vh",  left: "70vw"  },
  { img: 7, size: 130, rotate:   8, top: "18vh",  left: "92vw"  },

  { img: 2, size: 125, rotate: -19, top: "41vh",  left:  "2vw"  },
  { img: 6, size: 108, rotate:  35, top: "37vh",  left: "22vw"  },
  { img: 8, size: 140, rotate: -44, top: "44vh",  left: "44vw"  },
  { img: 0, size: 116, rotate:  12, top: "39vh",  left: "66vw"  },
  { img: 4, size: 134, rotate: -26, top: "43vh",  left: "87vw"  },

  { img: 3, size: 120, rotate:  39, top: "62vh",  left:  "9vw"  },
  { img: 7, size: 112, rotate: -11, top: "58vh",  left: "31vw"  },
  { img: 9, size: 136, rotate:  22, top: "65vh",  left: "53vw"  },
  { img: 5, size: 126, rotate: -40, top: "60vh",  left: "75vw"  },
  { img: 1, size: 118, rotate:  16, top: "63vh",  left: "94vw"  },

  { img: 6, size: 130, rotate: -28, top: "80vh",  left:  "3vw"  },
  { img: 8, size: 106, rotate:  44, top: "85vh",  left: "24vw"  },
  { img: 2, size: 142, rotate:  -9, top: "78vh",  left: "46vw"  },
  { img: 0, size: 114, rotate:  33, top: "83vh",  left: "68vw"  },
  { img: 9, size: 124, rotate: -20, top: "80vh",  left: "89vw"  },
];
---

<div class="stickers-layer" aria-hidden="true">
  {stickers.map((s, i) => (
    <img
      class="sticker"
      src={`/stickers/${imgs[s.img]}`}
      alt=""
      width={s.size}
      height={s.size}
      style={`top:${s.top};left:${s.left};--size:${s.size}px;--rot:${s.rotate}deg;--delay:${i * 50}ms`}
      loading="lazy"
      draggable="false"
    />
  ))}
</div>

<style>
  .stickers-layer {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
  }

  .sticker {
    position: absolute;
    width:  var(--size);
    height: var(--size);
    object-fit: contain;
    transform: rotate(var(--rot));
    filter: drop-shadow(2px 4px 8px rgba(0,0,0,0.18));
    animation: sticker-pop 0.45s cubic-bezier(0.34,1.4,0.64,1) var(--delay) both;
  }

  @keyframes sticker-pop {
    from { opacity: 0; transform: rotate(var(--rot)) scale(0.4); }
    to   { opacity: 1; transform: rotate(var(--rot)) scale(1);   }
  }

  @media (max-width: 600px) {
    .sticker {
      width:  calc(var(--size) * 0.55);
      height: calc(var(--size) * 0.55);
    }

    /* Ocultar los stickers pares — quedan 10 de 20, uno por celda aprox */
    .sticker:nth-child(even) {
      display: none;
    }
  }
</style>
