---
// 16 instancias repartidas por todo el viewport (los 8 archivos se repiten).
// Como son position:fixed, siempre decoran el fondo independientemente del scroll.
// El contenido tiene z-index:2 → siempre encima de los stickers.

const imgs = [
  "mollo", "coqui", "nara", "coqui2",
  "coqui3", "coquimollo", "nara2", "nara3",
];

const stickers = [
  // ── Fila superior ──────────────────────────────────────────────
  { img: 0, size: 130, rotate: -14, top:  "4vh",  left:  "3vw"  },
  { img: 4, size: 115, rotate:  18, top:  "2vh",  left: "28vw"  },
  { img: 2, size: 140, rotate:  -6, top:  "5vh",  left: "52vw"  },
  { img: 6, size: 118, rotate:  20, top:  "3vh",  left: "78vw"  },

  // ── Fila media-alta ─────────────────────────────────────────────
  { img: 1, size: 125, rotate: -20, top: "30vh",  left:  "1vw"  },
  { img: 5, size: 138, rotate:  11, top: "25vh",  left: "35vw"  },
  { img: 3, size: 122, rotate: -9,  top: "28vh",  left: "68vw"  },
  { img: 7, size: 132, rotate:  16, top: "32vh",  left: "90vw"  },

  // ── Fila media-baja ─────────────────────────────────────────────
  { img: 2, size: 120, rotate:   8, top: "54vh",  left:  "5vw"  },
  { img: 6, size: 145, rotate: -17, top: "50vh",  left: "30vw"  },
  { img: 0, size: 128, rotate:  22, top: "56vh",  left: "62vw"  },
  { img: 4, size: 115, rotate:  -7, top: "52vh",  left: "87vw"  },

  // ── Fila inferior ───────────────────────────────────────────────
  { img: 3, size: 135, rotate: -12, top: "78vh",  left:  "2vw"  },
  { img: 7, size: 122, rotate:  15, top: "75vh",  left: "32vw"  },
  { img: 5, size: 140, rotate:  -4, top: "80vh",  left: "60vw"  },
  { img: 1, size: 118, rotate:  19, top: "76vh",  left: "84vw"  },
];
---

<div class="stickers-layer" aria-hidden="true">
  {stickers.map((s, i) => (
    <img
      class="sticker"
      src={`/stickers/${imgs[s.img]}.webp`}
      alt=""
      width={s.size}
      height={s.size}
      style={`top:${s.top};left:${s.left};--size:${s.size}px;--rot:${s.rotate}deg;--delay:${i * 50}ms`}
      loading="lazy"
      draggable="false"
    />
  ))}
</div>

<style>
  .stickers-layer {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
  }

  .sticker {
    position: absolute;
    width:  var(--size);
    height: var(--size);
    object-fit: contain;
    transform: rotate(var(--rot));
    filter: drop-shadow(2px 4px 8px rgba(0,0,0,0.18));
    animation: sticker-pop 0.45s cubic-bezier(0.34,1.4,0.64,1) var(--delay) both;
  }

  @keyframes sticker-pop {
    from { opacity: 0; transform: rotate(var(--rot)) scale(0.4); }
    to   { opacity: 1; transform: rotate(var(--rot)) scale(1);   }
  }

  @media (max-width: 600px) {
    .sticker {
      width:  calc(var(--size) * 0.55);
      height: calc(var(--size) * 0.55);
    }
  }
</style>
