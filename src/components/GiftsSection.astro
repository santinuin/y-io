---
const gifts = [
  { label: "Cena romántica",        emoji: "🍷" },
  { label: "Escapada de fin de semana", emoji: "✈️" },
  { label: "Spa day",               emoji: "💆" },
  { label: "Concierto sorpresa",    emoji: "🎶" },
  { label: "Picnic bajo las estrellas", emoji: "🌙" },
  { label: "Día de películas",      emoji: "🎬" },
];
---

<section class="gifts-section" id="gifts-section">
  <div class="gifts-header">
    <h2 class="gifts-title">Tus regalos te esperan</h2>
    <p class="gifts-subtitle">Toca una caja para descubrir tu sorpresa</p>
  </div>

  <div class="canvas-wrapper" id="canvas-wrapper">
    <canvas id="gifts-canvas"></canvas>
  </div>

  <!-- Overlay que aparece al abrir una caja -->
  <div class="gift-overlay" id="gift-overlay" aria-hidden="true">
    <div class="gift-card">
      <div class="gift-card-emoji" id="gift-emoji">🎁</div>
      <h3 class="gift-card-title" id="gift-title">Regalo</h3>
      <p class="gift-card-desc" id="gift-desc">¡Una sorpresa especial para vos!</p>
      <button class="gift-card-close" id="gift-close">Cerrar ✕</button>
    </div>
  </div>
</section>

<script>
  import Matter from "matter-js";

  const { Engine, Render, Runner, Bodies, Composite, Events, Query } = Matter;

  /* ── Referencias al DOM ── */
  const section   = document.getElementById("gifts-section")!;
  const wrapper   = document.getElementById("canvas-wrapper")!;
  const canvas    = document.getElementById("gifts-canvas") as HTMLCanvasElement;
  const overlay   = document.getElementById("gift-overlay")!;
  const emojiEl   = document.getElementById("gift-emoji")!;
  const titleEl   = document.getElementById("gift-title")!;
  const closeBtn  = document.getElementById("gift-close")!;

  /* ── Datos de los regalos (sincronizados con el frontmatter) ── */
  const GIFTS = [
    { label: "Cena romántica",            emoji: "🍷", desc: "Una noche especial solo para los dos." },
    { label: "Escapada de fin de semana", emoji: "✈️", desc: "Un destino sorpresa, solo vos y yo." },
    { label: "Spa day",                   emoji: "💆", desc: "Un día de descanso y mimos que te merecés." },
    { label: "Concierto sorpresa",        emoji: "🎶", desc: "Tu artista favorito, juntos en vivo." },
    { label: "Picnic bajo las estrellas", emoji: "🌙", desc: "Una noche mágica al aire libre." },
    { label: "Día de películas",          emoji: "🎬", desc: "Pijamas, pochoclo y maratón de tus favoritas." },
  ];

  let engineRef: Matter.Engine | null = null;
  let initialized = false;

  /* ══════════════════════════════════
     INICIALIZAR MATTER.JS
  ══════════════════════════════════ */
  function initMatter() {
    const W = wrapper.clientWidth;
    const H = wrapper.clientHeight;

    canvas.width  = W;
    canvas.height = H;

    /* Motor y renderer */
    const engine = Engine.create({ gravity: { x: 0, y: 1.2 } });
    engineRef = engine;

    const render = Render.create({
      canvas,
      engine,
      options: {
        width: W,
        height: H,
        background: "transparent",
        wireframes: false,
      },
    });

    /* ── Límites estáticos ── */
    const thickness = 60;
    const floor = Bodies.rectangle(W / 2, H + thickness / 2, W + thickness * 2, thickness, {
      isStatic: true, label: "floor",
      render: { fillStyle: "transparent", strokeStyle: "transparent", lineWidth: 0 },
    });
    const wallL = Bodies.rectangle(-thickness / 2, H / 2, thickness, H * 2, {
      isStatic: true, label: "wall",
      render: { fillStyle: "transparent", strokeStyle: "transparent", lineWidth: 0 },
    });
    const wallR = Bodies.rectangle(W + thickness / 2, H / 2, thickness, H * 2, {
      isStatic: true, label: "wall",
      render: { fillStyle: "transparent", strokeStyle: "transparent", lineWidth: 0 },
    });
    Composite.add(engine.world, [floor, wallL, wallR]);

    /* ── Cajas de regalo ── */
    const boxW = Math.min(W * 0.16, 110);
    const boxH = boxW * 0.85;
    const cols  = Math.min(GIFTS.length, 3);
    const spacing = W / (cols + 1);

    GIFTS.forEach((gift, i) => {
      const col   = i % cols;
      const row   = Math.floor(i / cols);
      const x     = spacing * (col + 1) + (Math.random() - 0.5) * 30;
      const startY = -(boxH * 1.5) - row * (boxH + 40) - Math.random() * 60;

      const box = Bodies.rectangle(x, startY, boxW, boxH, {
        label: gift.label,
        restitution: 0.35,
        friction: 0.6,
        frictionAir: 0.012,
        render: {
          fillStyle: `hsl(${270 + i * 22}, 65%, 42%)`,
          strokeStyle: `hsl(${270 + i * 22}, 80%, 65%)`,
          lineWidth: 2,
        },
      });
      Composite.add(engine.world, box);
    });

    /* ── Renderizador de emojis sobre el canvas ── */
    const ctx = canvas.getContext("2d")!;

    Events.on(render, "afterRender", () => {
      const bodies = Composite.allBodies(engine.world).filter(
        (b) => b.label !== "floor" && b.label !== "wall"
      );

      bodies.forEach((body) => {
        const gift = GIFTS.find((g) => g.label === body.label);
        if (!gift) return;

        ctx.save();
        ctx.translate(body.position.x, body.position.y);
        ctx.rotate(body.angle);

        /* Emoji centrado */
        ctx.font = `${Math.min(boxW * 0.38, 36)}px serif`;
        ctx.textAlign = "center";
        ctx.textBaseline = "middle";
        ctx.fillText(gift.emoji, 0, -(boxH * 0.13));

        /* Nombre del regalo */
        ctx.font = `bold ${Math.min(boxW * 0.13, 11)}px sans-serif`;
        ctx.fillStyle = "rgba(255,255,255,0.9)";
        ctx.fillText(gift.label, 0, boxH * 0.27);

        ctx.restore();
      });
    });

    /* ── Runner ── */
    const runner = Runner.create();
    Runner.run(runner, engine);
    Render.run(render);

    /* ── Detección de clics / taps ── */
    canvas.addEventListener("click", handleCanvasClick);
    canvas.addEventListener("touchend", (e: TouchEvent) => {
      e.preventDefault();
      const touch = e.changedTouches[0];
      if (touch) handleCanvasClick({ clientX: touch.clientX, clientY: touch.clientY } as MouseEvent);
    }, { passive: false });

    function handleCanvasClick(e: MouseEvent) {
      const rect  = canvas.getBoundingClientRect();
      const point = { x: e.clientX - rect.left, y: e.clientY - rect.top };

      const hit = Query.point(Composite.allBodies(engine.world), point).find(
        (b) => b.label !== "floor" && b.label !== "wall"
      );

      if (!hit) return;

      /* Pequeño "rebote" visual antes de desaparecer */
      Matter.Body.applyForce(hit, hit.position, { x: 0, y: -0.06 });

      setTimeout(() => {
        Composite.remove(engine.world, hit);
        showGift(hit.label);
      }, 160);
    }

    /* ── Redimensionar canvas si la ventana cambia ── */
    window.addEventListener("resize", () => {
      const nW = wrapper.clientWidth;
      const nH = wrapper.clientHeight;
      canvas.width  = nW;
      canvas.height = nH;
      render.options.width  = nW;
      render.options.height = nH;
      render.canvas.width   = nW;
      render.canvas.height  = nH;
    });
  }

  /* ══════════════════════════════════
     MOSTRAR OVERLAY DE REGALO
  ══════════════════════════════════ */
  function showGift(label: string) {
    const gift = GIFTS.find((g) => g.label === label);
    if (!gift) return;

    emojiEl.textContent = gift.emoji;
    titleEl.textContent = gift.label;
    document.getElementById("gift-desc")!.textContent = gift.desc;

    overlay.classList.add("visible");
    overlay.setAttribute("aria-hidden", "false");
  }

  closeBtn.addEventListener("click", () => {
    overlay.classList.remove("visible");
    overlay.setAttribute("aria-hidden", "true");
  });

  overlay.addEventListener("click", (e) => {
    if (e.target === overlay) {
      overlay.classList.remove("visible");
      overlay.setAttribute("aria-hidden", "true");
    }
  });

  /* ══════════════════════════════════
     INTERSECTION OBSERVER
     Dispara Matter.js solo cuando la
     sección es visible (30% del viewport)
  ══════════════════════════════════ */
  const observer = new IntersectionObserver(
    (entries) => {
      if (entries[0].isIntersecting && !initialized) {
        initialized = true;
        initMatter();
        observer.disconnect();
      }
    },
    { threshold: 0.3 }
  );
  observer.observe(section);
</script>

<style>
  .gifts-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    background: linear-gradient(180deg, var(--color-bg) 0%, #110820 100%);
    padding-top: 4rem;
    overflow: hidden;
  }

  .gifts-header {
    text-align: center;
    z-index: 1;
    margin-bottom: 2rem;
  }

  .gifts-title {
    font-size: clamp(1.6rem, 4vw, 2.8rem);
    font-weight: 400;
    color: var(--color-text);
    text-shadow: 0 0 40px rgba(224, 64, 251, 0.5);
    margin-bottom: 0.5rem;
  }

  .gifts-subtitle {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    letter-spacing: 0.08em;
  }

  .canvas-wrapper {
    position: relative;
    width: 100%;
    flex: 1;
    min-height: 600px;
  }

  #gifts-canvas {
    display: block;
    width: 100%;
    height: 100%;
    cursor: pointer;
  }

  /* ── Overlay ── */
  .gift-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 100;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
    backdrop-filter: blur(4px);
  }

  .gift-overlay.visible {
    opacity: 1;
    pointer-events: all;
  }

  .gift-card {
    background: linear-gradient(135deg, #1e0f35 0%, #2d1060 100%);
    border: 1px solid rgba(224, 64, 251, 0.35);
    border-radius: 1.5rem;
    padding: 2.5rem 3rem;
    text-align: center;
    max-width: 380px;
    width: 90%;
    box-shadow:
      0 0 40px rgba(224, 64, 251, 0.2),
      0 20px 60px rgba(0, 0, 0, 0.5);
    transform: scale(0.85);
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .gift-overlay.visible .gift-card {
    transform: scale(1);
  }

  .gift-card-emoji {
    font-size: 4rem;
    margin-bottom: 1rem;
    display: block;
    animation: spin-in 0.5s ease both;
  }

  @keyframes spin-in {
    from { transform: rotate(-30deg) scale(0); opacity: 0; }
    to   { transform: rotate(0deg) scale(1);   opacity: 1; }
  }

  .gift-card-title {
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .gift-card-desc {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.8rem;
  }

  .gift-card-close {
    background: linear-gradient(135deg, var(--color-accent-2), var(--color-accent));
    color: #fff;
    border: none;
    border-radius: 2rem;
    padding: 0.65rem 2rem;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .gift-card-close:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(224, 64, 251, 0.35);
  }
</style>
