---
/**
 * WaveText — texto animado en forma de ola sinusoidal.
 * Cada carácter se posiciona con translate + rotate calculados
 * a partir de la derivada de la curva (tangente a la ola),
 * replicando la técnica del TextScroll de Ricola.
 *
 * Con scrollDriven=true la fase de la ola está 100% ligada al scroll:
 * no hay animación autónoma. El scroll avanza/retrocede la ola.
 */
interface Props {
  text: string;
  /** Altura máxima de la ola en px */
  amplitude?: number;
  /** Ciclos de ola distribuidos sobre el texto */
  frequency?: number;
  /** Separación horizontal entre caracteres en px */
  charWidth?: number;
  /** Tamaño de fuente en px */
  fontSize?: number;
  /**
   * Cuántos radianes recorre la fase de la ola de scroll=0 a scroll=1.
   * Más alto = la ola "gira" más mientras el texto cruza la pantalla.
   * Default: Math.PI * 3  (1.5 ciclos completos)
   */
  phaseRange?: number;
  /** Suavizado del lerp (0-1). Más bajo = más lag / más suave. */
  lerpFactor?: number;
  /**
   * Cuando true, el contenedor entra por la derecha, cruza centrado
   * y sale por la izquierda, sincronizado con el scroll del hero.
   */
  scrollDriven?: boolean;
}

const {
  text,
  amplitude    = 28,
  frequency    = 0.9,
  charWidth    = 26,
  fontSize     = 32,
  phaseRange   = Math.PI * 3,
  lerpFactor   = 0.1,
  scrollDriven = false,
} = Astro.props;

const chars      = text.split("");
const totalWidth = chars.length * charWidth;
const containerH = amplitude * 2 + fontSize * 1.8;
---

<div
  class:list={["wave-text-root", scrollDriven && "is-scroll-driven"]}
  id="wave-text-root"
  data-amplitude={amplitude}
  data-frequency={frequency}
  data-char-width={charWidth}
  data-phase-range={phaseRange}
  data-lerp-factor={lerpFactor}
  data-total={chars.length}
  data-total-width={totalWidth}
  data-scroll-driven={scrollDriven}
  style={`--wt-height:${containerH}px; --wt-width:${totalWidth}px; --wt-font-size:${fontSize}px;`}
>
  <span class="wt-sr-only">{text}</span>

  {chars.map((char, i) => (
    <span class="wt-char" aria-hidden="true">
      {char === " " ? "\u00A0" : char}
    </span>
  ))}
</div>

<script>
  const root  = document.getElementById("wave-text-root") as HTMLElement;
  const spans = root.querySelectorAll<HTMLElement>(".wt-char");

  const amplitude    = parseFloat(root.dataset.amplitude   ?? "28");
  const frequency    = parseFloat(root.dataset.frequency   ?? "0.9");
  const charWidth    = parseFloat(root.dataset.charWidth   ?? "26");
  const phaseRange   = parseFloat(root.dataset.phaseRange  ?? String(Math.PI * 3));
  const lerpFactor   = parseFloat(root.dataset.lerpFactor  ?? "0.1");
  const total        = parseInt  (root.dataset.total       ?? "1");
  const totalWidth   = parseFloat(root.dataset.totalWidth  ?? "0");
  const scrollDriven = root.dataset.scrollDriven === "true";

  let scrollProgress = 0;   // 0 → 1, actualizado en onScroll
  let phase          = 0;   // fase actual (lerpeada hacia targetPhase)
  let targetPhase    = 0;   // fase objetivo dictada por el scroll

  /* ── Fuente del scroll ── */
  const wrapper = document.getElementById("hero-sticky-wrapper");
  const hero    = document.getElementById("hero");

  function onScroll() {
    if (wrapper) {
      const scrollableH = wrapper.offsetHeight - window.innerHeight;
      const relScroll   = window.scrollY - wrapper.offsetTop;
      scrollProgress    = Math.max(0, Math.min(relScroll / scrollableH, 1));
    } else if (hero) {
      scrollProgress = Math.min(window.scrollY / hero.offsetHeight, 1);
    }

    // ── La fase objetivo es una función directa del scroll ──
    // El scroll lleva la ola de 0 a phaseRange radianes.
    targetPhase = scrollProgress * phaseRange;
  }

  window.addEventListener("scroll", onScroll, { passive: true });

  /* ── Loop de render ── */
  function render() {
    // Lerp suave: la fase actual se acerca a la objetivo cada frame.
    // Esto evita saltos bruscos si el scroll es rápido o discreto.
    phase += (targetPhase - phase) * lerpFactor;

    /* ── Posición del contenedor (scroll-driven) ── */
    if (scrollDriven) {
      // Entra por la DERECHA, sale por la IZQUIERDA
      // progress=0   → +slideDistance  (fuera a la derecha)
      // progress=0.5 → 0               (centrado)
      // progress=1   → -slideDistance  (fuera a la izquierda)
      const slideDistance = window.innerWidth + totalWidth / 2;
      const containerX    = slideDistance * (1 - 2 * scrollProgress);
      root.style.transform = `translateX(${containerX.toFixed(1)}px)`;

      // Fade-in primer 15% · opaco en el centro · fade-out último 15%
      const opacity = Math.min(scrollProgress / 0.15, 1, (1 - scrollProgress) / 0.15);
      root.style.opacity = opacity.toFixed(4);
    }

    /* ── Posicionar cada carácter sobre la ola ── */
    spans.forEach((span, i) => {
      // theta: posición de este carácter en el ciclo sinusoidal
      const theta  = (i / total) * frequency * Math.PI * 2 - phase;

      // X: distribución lineal centrada en el contenedor
      const x      = i * charWidth - totalWidth / 2 + charWidth / 2;

      // Y: curva sinusoidal
      const y      = amplitude * Math.sin(theta);

      // Rotación: tangente de la curva (derivada del seno = coseno)
      const dy     = amplitude * (frequency * Math.PI * 2 / total) * Math.cos(theta);
      const rotDeg = Math.atan2(dy, charWidth) * (180 / Math.PI);

      span.style.transform =
        `translate(${x.toFixed(2)}px, ${y.toFixed(2)}px) rotate(${rotDeg.toFixed(3)}deg)`;
    });

    requestAnimationFrame(render);
  }

  requestAnimationFrame(render);
</script>

<style>
  .wave-text-root {
    position: relative;
    width: var(--wt-width);
    height: var(--wt-height);
    max-width: none;
    flex-shrink: 0;
    will-change: transform, opacity;
  }

  .wave-text-root.is-scroll-driven {
    opacity: 0;
    transform: translateX(200vw);
  }

  .wt-sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  .wt-char {
    position: absolute;
    top: 50%; left: 50%;
    display: inline-block;
    font-size: var(--wt-font-size);
    line-height: 1;
    will-change: transform;
  }

  .wave-text-root:not(.is-scroll-driven) .wt-char {
    animation: wt-fade-in 0.5s ease both;
  }

  @keyframes wt-fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
</style>
