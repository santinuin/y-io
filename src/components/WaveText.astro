---
/**
 * WaveText — texto animado en forma de ola sinusoidal.
 * Cada carácter se posiciona con translate + rotate calculados
 * a partir de la derivada de la curva (tangente a la ola),
 * replicando la técnica del TextScroll de Ricola.
 *
 * Con scrollDriven=true el contenedor entero aparece desde la
 * izquierda, llega al centro y vuelve a salir por la izquierda
 * a medida que el usuario hace scroll en la sección hero.
 */
interface Props {
  text: string;
  /** Altura máxima de la ola en px */
  amplitude?: number;
  /** Ciclos de ola sobre el texto completo */
  frequency?: number;
  /** Separación horizontal entre caracteres en px */
  charWidth?: number;
  /** Tamaño de fuente en px */
  fontSize?: number;
  /** Velocidad de la animación (radianes por segundo) */
  speed?: number;
  /**
   * Cuando true, el contenedor completo entra y sale por la izquierda
   * sincronizado con el scroll del hero (#hero).
   */
  scrollDriven?: boolean;
}

const {
  text,
  amplitude   = 28,
  frequency   = 0.9,
  charWidth   = 26,
  fontSize    = 32,
  speed       = 1.4,
  scrollDriven = false,
} = Astro.props;

const chars         = text.split("");
const totalWidth    = chars.length * charWidth;
const containerH    = amplitude * 2 + fontSize * 1.8;
---

<div
  class:list={["wave-text-root", scrollDriven && "is-scroll-driven"]}
  id="wave-text-root"
  data-amplitude={amplitude}
  data-frequency={frequency}
  data-char-width={charWidth}
  data-font-size={fontSize}
  data-speed={speed}
  data-total={chars.length}
  data-total-width={totalWidth}
  data-scroll-driven={scrollDriven}
  style={`--wt-height:${containerH}px; --wt-width:${totalWidth}px; --wt-font-size:${fontSize}px;`}
>
  <span class="wt-sr-only">{text}</span>

  {chars.map((char, i) => (
    <span class="wt-char" aria-hidden="true" data-i={i}>
      {char === " " ? "\u00A0" : char}
    </span>
  ))}
</div>

<script>
  const root  = document.getElementById("wave-text-root") as HTMLElement;
  const spans = root.querySelectorAll<HTMLElement>(".wt-char");

  const amplitude    = parseFloat(root.dataset.amplitude    ?? "28");
  const frequency    = parseFloat(root.dataset.frequency    ?? "0.9");
  const charWidth    = parseFloat(root.dataset.charWidth    ?? "26");
  const speed        = parseFloat(root.dataset.speed        ?? "1.4");
  const total        = parseInt  (root.dataset.total        ?? "1");
  const totalWidth   = parseFloat(root.dataset.totalWidth   ?? "0");
  const scrollDriven = root.dataset.scrollDriven === "true";

  let phase          = 0;
  let lastTime       = 0;
  let scrollProgress = 0;   // 0 → 1 dentro del hero

  /* ── Scroll: usa el wrapper sticky si existe, si no el hero ── */
  const wrapper = document.getElementById("hero-sticky-wrapper");
  const hero    = document.getElementById("hero");

  function onScroll() {
    if (wrapper) {
      // El espacio scrolleable del wrapper es (wrapperHeight - windowHeight)
      const scrollableH = wrapper.offsetHeight - window.innerHeight;
      const relScroll   = window.scrollY - wrapper.offsetTop;
      scrollProgress    = Math.max(0, Math.min(relScroll / scrollableH, 1));
    } else if (hero) {
      scrollProgress = Math.min(window.scrollY / hero.offsetHeight, 1);
    }
  }
  window.addEventListener("scroll", onScroll, { passive: true });

  /* ── Loop principal ── */
  function render(now: number) {
    const dt = Math.min((now - lastTime) / 1000, 0.05);
    lastTime = now;

    /* ─────────────────────────────────────────────────────
       MODO SCROLL-DRIVEN
       curve = sin(progress × π)
         → 0 al inicio, 1 al centro del scroll, 0 al final
       El contenedor entra desde la izquierda, llega al centro
       y vuelve a salir por la izquierda.
    ───────────────────────────────────────────────────── */
    if (scrollDriven) {
      // Distancia suficiente para salir completamente del viewport
      const slideDistance = window.innerWidth + totalWidth / 2;

      // Movimiento lineal: entra por la DERECHA, sale por la IZQUIERDA
      // progress=0 → +slideDistance (derecha, fuera)
      // progress=0.5 → 0 (centro)
      // progress=1 → -slideDistance (izquierda, fuera)
      const containerX = slideDistance * (1 - 2 * scrollProgress);
      root.style.transform = `translateX(${containerX.toFixed(1)}px)`;

      // Opacidad: fade-in en el primer 15%, plena en el medio,
      // fade-out en el último 15%
      const opacity = Math.min(scrollProgress / 0.15, 1, (1 - scrollProgress) / 0.15);
      root.style.opacity = opacity.toFixed(4);

      // La ola avanza a velocidad constante
      phase += speed * dt;
    } else {
      // Comportamiento original: la ola avanza siempre
      phase += speed * dt * (1 + scrollProgress * 1.5);
    }

    // Amplitud se mantiene constante en modo scroll-driven
    // (la visibilidad ya la controla la opacidad del contenedor)
    const currentAmplitude = scrollDriven
      ? amplitude
      : amplitude * (1 - scrollProgress * 0.75);

    /* ─ Posicionar cada carácter ─ */
    spans.forEach((span, i) => {
      const theta  = (i / total) * frequency * Math.PI * 2 - phase;
      const x      = i * charWidth - totalWidth / 2 + charWidth / 2;
      const y      = currentAmplitude * Math.sin(theta);
      const dy     = currentAmplitude * (frequency * Math.PI * 2 / total) * Math.cos(theta);
      const rotDeg = Math.atan2(dy, charWidth) * (180 / Math.PI);

      span.style.transform =
        `translate(${x.toFixed(2)}px, ${y.toFixed(2)}px) rotate(${rotDeg.toFixed(3)}deg)`;
    });

    requestAnimationFrame(render);
  }

  requestAnimationFrame((t) => { lastTime = t; render(t); });
</script>

<style>
  .wave-text-root {
    position: relative;
    width: var(--wt-width);
    height: var(--wt-height);
    max-width: none;   /* No recortar: el hero.overflow:hidden se encarga */
    flex-shrink: 0;
    will-change: transform, opacity;
  }

  /* Estado inicial cuando el scroll controla la posición:
     invisible y empujado a la izquierda hasta que el JS tome el control */
  .wave-text-root.is-scroll-driven {
    opacity: 0;
    transform: translateX(200vw);  /* fuera del viewport por la derecha */
  }

  .wt-sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  .wt-char {
    position: absolute;
    top: 50%; left: 50%;
    display: inline-block;
    font-size: var(--wt-font-size);
    line-height: 1;
    will-change: transform;
  }

  /* Solo mostrar fade-in en modo normal (no scroll-driven) */
  .wave-text-root:not(.is-scroll-driven) .wt-char {
    animation: wt-fade-in 0.5s ease both;
  }

  @keyframes wt-fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
</style>
