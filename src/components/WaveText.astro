---
/**
 * WaveText — texto animado en forma de ola sinusoidal.
 * Cada carácter se posiciona con translate + rotate calculados
 * a partir de la derivada de la curva (tangente a la ola),
 * replicando la técnica del TextScroll de Ricola.
 */
interface Props {
  text: string;
  /** Altura máxima de la ola en px */
  amplitude?: number;
  /** Ciclos de ola sobre el texto completo (1 = un ciclo completo) */
  frequency?: number;
  /** Separación horizontal entre caracteres en px */
  charWidth?: number;
  /** Tamaño de fuente en px */
  fontSize?: number;
  /** Velocidad de la animación (radianes por segundo) */
  speed?: number;
}

const {
  text,
  amplitude = 28,
  frequency = 0.9,
  charWidth = 26,
  fontSize = 32,
  speed = 1.4,
} = Astro.props;

const chars = text.split("");
const totalWidth = chars.length * charWidth;
// Altura del contenedor: deja espacio para la ola + rotaciones extremas
const containerHeight = amplitude * 2 + fontSize * 1.8;
---

<div
  class="wave-text-root"
  id="wave-text-root"
  data-amplitude={amplitude}
  data-frequency={frequency}
  data-char-width={charWidth}
  data-font-size={fontSize}
  data-speed={speed}
  data-total={chars.length}
  style={`--wt-height: ${containerHeight}px; --wt-width: ${totalWidth}px; --wt-font-size: ${fontSize}px;`}
>
  {/* Texto real para lectores de pantalla */}
  <span class="wt-sr-only">{text}</span>

  {/* Un span por carácter, ocultado de los lectores de pantalla */}
  {chars.map((char, i) => (
    <span
      class="wt-char"
      aria-hidden="true"
      data-i={i}
    >
      {char === " " ? "\u00A0" : char}
    </span>
  ))}
</div>

<script>
  const root = document.getElementById("wave-text-root") as HTMLElement;
  const spans = root.querySelectorAll<HTMLElement>(".wt-char");

  // Leer configuración desde data-attributes
  const amplitude  = parseFloat(root.dataset.amplitude  ?? "28");
  const frequency  = parseFloat(root.dataset.frequency  ?? "0.9");
  const charWidth  = parseFloat(root.dataset.charWidth  ?? "26");
  const speed      = parseFloat(root.dataset.speed      ?? "1.4");
  const total      = parseInt(root.dataset.total        ?? "1");

  // Ancho total y offset para centrar la ola dentro del contenedor
  const totalWidth = total * charWidth;

  let phase     = 0;          // offset de fase — avanza cada frame
  let lastTime  = 0;
  let scrollProgress = 0;     // 0 → 1 según el scroll del hero

  /* ── Sincronizar scroll del hero ── */
  const hero = document.getElementById("hero");
  function onScroll() {
    if (!hero) return;
    scrollProgress = Math.min(window.scrollY / hero.offsetHeight, 1);
  }
  window.addEventListener("scroll", onScroll, { passive: true });

  /* ── Loop principal ── */
  function render(now: number) {
    const dt = Math.min((now - lastTime) / 1000, 0.05); // delta en segundos, máx 50ms
    lastTime = now;

    // La ola se acelera suavemente conforme el usuario baja
    phase += speed * dt * (1 + scrollProgress * 1.5);

    // Amplitud se reduce con el scroll (el texto "se aplana" al bajar)
    const currentAmplitude = amplitude * (1 - scrollProgress * 0.75);

    spans.forEach((span, i) => {
      // Ángulo del carácter i en la ola
      const theta = (i / total) * frequency * Math.PI * 2 - phase;

      // Posición X: distribución lineal, centrada
      const x = i * charWidth - totalWidth / 2 + charWidth / 2;

      // Posición Y: curva sinusoidal
      const y = currentAmplitude * Math.sin(theta);

      // Rotación: ángulo de la tangente (derivada del seno = coseno)
      const dy = currentAmplitude * (frequency * Math.PI * 2 / total) * Math.cos(theta);
      const rotDeg = Math.atan2(dy, charWidth) * (180 / Math.PI);

      span.style.transform = `translate(${x.toFixed(2)}px, ${y.toFixed(2)}px) rotate(${rotDeg.toFixed(3)}deg)`;
    });

    requestAnimationFrame(render);
  }

  requestAnimationFrame((t) => { lastTime = t; render(t); });
</script>

<style>
  /* Contenedor relativo: define el espacio de la ola */
  .wave-text-root {
    position: relative;
    width: var(--wt-width);
    height: var(--wt-height);
    max-width: 100%;
    /* Centrar horizontalmente si el padre es flex */
    flex-shrink: 0;
  }

  /* Texto accesible, visualmente oculto */
  .wt-sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Cada carácter flota sobre el contenedor */
  .wt-char {
    position: absolute;
    /* Anclar el origen de la transformación al centro de la letra */
    top: 50%;
    left: 50%;
    display: inline-block;
    font-size: var(--wt-font-size);
    line-height: 1;
    will-change: transform;
    /* Entrada suave al cargar */
    animation: wt-fade-in 0.5s ease both;
  }

  @keyframes wt-fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
</style>
